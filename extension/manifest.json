{
  "manifest_version": 3,
  "name": "U of T Prompt Sanitizer",
  "version": "0.1.0",
  "description": "Detect and remove sensitive information before pasting into AI tools. Built for the University of Toronto community.",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "notifications",
    "scripting",
    "activeTab",
    "offscreen"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content/content-script.js"],
      "css": ["content/toast.css"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/copy-intercept.js"]
    }
  ],
  "commands": {
    "sanitize-clipboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Sanitize selected text and copy to clipboard"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
